{
  "name": "@hotdoc/api",
  "version": "0.1.0",
  "private": true,
  "description": "HotDoc Backend (Node.js + Express) — Alarm-Poller, syBOS-Sync, PDF-Gen, WebPush",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hotdoc/shared": "workspace:*",
    "express": "4.21.2",
    "cors": "2.8.5",
    "helmet": "8.0.0",
    "compression": "1.7.5",
    "morgan": "1.10.0",
    "pino": "9.6.0",
    "pino-pretty": "13.0.0",
    "pino-http": "10.4.0",
    "nano": "10.1.4",
    "node-cron": "3.0.3",
    "web-push": "3.6.7",
    "puppeteer": "23.11.1",
    "bcryptjs": "2.4.3",
    "jose": "5.9.6",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/compression": "1.7.5",
    "@types/express": "5.0.0",
    "@types/morgan": "1.9.9",
    "@types/node-cron": "3.0.11",
    "@types/web-push": "3.6.4",
    "@types/bcryptjs": "2.4.6",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8",
    "supertest": "7.0.0",
    "@types/supertest": "6.0.2"
  }
}
