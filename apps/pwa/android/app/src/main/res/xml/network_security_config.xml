<?xml version="1.0" encoding="utf-8"?>
<!--
    Network-Security-Config: TLS-only fuer alle Backend-Calls.

    HotDoc-API laeuft ausschliesslich ueber HTTPS (fly.io stellt das
    auf jedem App-Endpunkt sicher). Kein Cleartext erlaubt — wenn ein
    Angreifer DNS umlenkt, soll der Webview die Verbindung nicht aufbauen.

    Falls fuer lokale Entwicklung Cleartext gebraucht wird (z. B.
    http://192.168.x.x:5173 oder gegen lokale CouchDB), kann in
    capacitor.config.ts der server.cleartext=true gesetzt UND hier eine
    Domain-Override-Regel ergaenzt werden. NICHT fuer Produktion.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
