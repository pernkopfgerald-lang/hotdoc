{
  admin off
  auto_https off
}

:8080 {
  root * /srv
  encode gzip

  # Healthz-Endpoint fuer fly's HTTP-Check.
  handle /healthz {
    respond "ok" 200
  }

  # APK-Auslieferung: stabile Cache-Header damit Tablets sie nicht
  # bei jedem Update-Check neu laden. Versionsnummer ist im Filename
  # eindeutig, daher safe.
  handle /*.apk {
    header Cache-Control "public, max-age=86400, immutable"
    header Content-Type "application/vnd.android.package-archive"
    file_server browse {
      hide /healthz
    }
  }

  # /_all → File-Browser fuer alle APKs (Archiv-Uebersicht)
  handle /_all* {
    rewrite * /
    file_server browse {
      hide /healthz /apk-info.json /index.html /ff-logo.png
    }
  }

  # / → schoene Landing mit aktueller Version + Release-Notes
  handle / {
    rewrite * /index.html
    file_server
  }

  # Sonstige requests (apk-info.json, ff-logo.png) → direkt
  handle {
    file_server
  }

  # Logs auf stdout
  log {
    output stdout
    format console
  }
}
