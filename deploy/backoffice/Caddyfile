:8080 {
  root * /srv
  encode gzip zstd

  respond /healthz "ok" 200

  # API-Proxy zur Backend-App. Fly-internal-Netz zwischen Apps verschiedener
  # Org-Apps ist nicht freigegeben — daher über public HTTPS-URL.
  # handle (statt handle_path) erhält den Originalpfad /api/* — das Backend
  # erwartet die /api-Präfix-Routes.
  handle /api/* {
    reverse_proxy https://hotdoc-api.fly.dev {
      header_up Host {upstream_hostport}
    }
  }

  # SPA-Fallback (alles andere)
  handle {
    @static {
      path *.css *.js *.woff2 *.svg *.png *.jpg *.webp *.ico
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    @html path *.html
    header @html Cache-Control "no-cache"

    try_files {path} {path}/ /index.html
    file_server
  }

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    -Server
  }

  log {
    output stdout
    format console
  }
}
