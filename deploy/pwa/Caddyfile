:8080 {
  root * /srv
  encode gzip zstd

  respond /healthz "ok" 200

  # PWA-Fallback: alle unbekannten Routen → index.html (Client-Side-Routing)
  try_files {path} {path}/ /index.html

  file_server

  @static {
    path *.css *.js *.woff2 *.svg *.png *.jpg *.webp *.ico
  }
  header @static Cache-Control "public, max-age=31536000, immutable"

  @html path *.html
  header @html Cache-Control "no-cache"

  # Service-Worker MUSS frisch geladen werden
  @sw path /sw.js /registerSW.js /workbox-*.js
  header @sw Cache-Control "no-cache, no-store, must-revalidate"

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "microphone=(self), geolocation=(self), camera=()"
    -Server
  }

  log {
    output stdout
    format console
  }
}
