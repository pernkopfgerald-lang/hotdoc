:8080 {
  root * /srv
  encode gzip zstd

  respond /healthz "ok" 200

  # API-Proxy zur Backend-App (gleiches Pattern wie Backoffice).
  # Fly-internal-Netzwerk zwischen Apps verschiedener fly-Apps ist nicht
  # freigegeben — daher über die public HTTPS-URL.
  # `handle` (statt `handle_path`) erhält den Originalpfad /api/* — das
  # Backend erwartet die /api-Präfix-Routes. Muss VOR dem SPA-Fallback
  # stehen, sonst rewrite-t try_files den Pfad auf /index.html.
  handle /api/* {
    reverse_proxy https://hotdoc-api.fly.dev {
      header_up Host {upstream_hostport}
    }
  }

  # SPA-Fallback + statisches Serving (alles andere als /api)
  handle {
    @static {
      path *.css *.js *.woff2 *.svg *.png *.jpg *.webp *.ico
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    @html path *.html
    header @html Cache-Control "no-cache"

    # Service-Worker MUSS frisch geladen werden
    @sw path /sw.js /registerSW.js /workbox-*.js
    header @sw Cache-Control "no-cache, no-store, must-revalidate"

    try_files {path} {path}/ /index.html
    file_server
  }

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "microphone=(self), geolocation=(self), camera=()"
    -Server
  }

  log {
    output stdout
    format console
  }
}
